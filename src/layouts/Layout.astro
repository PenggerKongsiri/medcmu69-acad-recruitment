---
import '../styles/index.css';
import { SITE_CONFIG } from '../data/recruitmentData';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'เปิดรับสมัครสมาชิกฝ่ายวิชาการ MEDCMU69',
  description = 'ศึกษารายละเอียด 8 ทีม รวม 29 ตำแหน่ง พร้อมขอบเขตงาน คุณสมบัติ และกรอกใบสมัครเข้าร่วมทีมฝ่ายวิชาการ MEDCMU69'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE_CONFIG.siteUrl);
const ogImageURL = new URL('/og-image.png', SITE_CONFIG.siteUrl);
---

<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph Metadata -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MEDCMU69 Academic Team" />
    <meta property="og:locale" content="th_TH" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:image" content={ogImageURL.toString()} />
    <meta property="og:image:secure_url" content={ogImageURL.toString()} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="เปิดรับสมัครสมาชิกฝ่ายวิชาการ MEDCMU69"
    />

    <!-- Twitter Card Metadata -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.toString()} />
    <meta
      name="twitter:image:alt"
      content="เปิดรับสมัครสมาชิกฝ่ายวิชาการ MEDCMU69"
    />

    <meta name="theme-color" content="#312e81" />

    <!-- Analytics Tracking -->
    <script defer src="https://analytics.fufy.cc/script.js" data-website-id="47aae4e2-f914-403d-bc94-24966b95bbfe"></script>
  </head>
  <body>
    <slot />
  </body>
</html>

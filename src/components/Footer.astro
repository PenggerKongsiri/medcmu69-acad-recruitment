---
import { SITE_CONFIG } from '../data/recruitmentData';
---

<footer class="footer">
  <div class="container footer-content">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="brand-info">
          <h3 class="footer-title">{SITE_CONFIG.orgNameEnglish}</h3>
          <p class="footer-faculty">{SITE_CONFIG.facultyEnglish}</p>
          <p class="footer-faculty-thai">{SITE_CONFIG.orgNameThai} • {SITE_CONFIG.facultyThai}</p>
        </div>
      </div>

      <div class="footer-cta">
        <a href="#apply" class="btn-primary footer-btn">
          <span>กรอกใบสมัครออนไลน์</span>
        </a>
      </div>
    </div>

    <div class="footer-disclaimer">
      <p>
        <strong>ข้อความชี้แจง (Recruitment Disclaimer):</strong> เว็บไซต์นี้จัดทำและดูแลรับผิดชอบโดยคณะทำงานฝ่ายวิชาการ นักศึกษาแพทย์ มหาวิทยาลัยเชียงใหม่ รุ่นที่ 69 (MEDCMU69 Academic Team) เพื่อวัตถุประสงค์ในการสื่อสารข้อมูลขอบเขตงานและรับสมัครสมาชิกทีมภายในรุ่นเท่านั้น มิได้เป็นเว็บไซต์หรือสื่อการประชาสัมพันธ์อย่างเป็นทางการของคณะแพทยศาสตร์หรือมหาวิทยาลัยเชียงใหม่
      </p>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} {SITE_CONFIG.orgNameEnglish}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--primary);
    color: #ffffff;
    padding: 3.5rem 0 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
    justify-content: space-between;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  @media (min-width: 640px) {
    .footer-top {
      flex-direction: row;
      align-items: center;
    }
  }

  .footer-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 0.25rem;
  }

  .footer-faculty {
    font-size: 0.9375rem;
    color: #E0E7FF;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .footer-faculty-thai {
    font-size: 0.85rem;
    color: #94A3B8;
  }

  .footer-disclaimer {
    background: rgba(255, 255, 255, 0.05);
    border-left: 3px solid var(--accent);
    padding: 1rem 1.25rem;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .footer-disclaimer p {
    font-size: 0.85rem;
    color: #CBD5E1;
    line-height: 1.65;
  }

  .footer-disclaimer strong {
    color: #ffffff;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.8125rem;
    color: #94A3B8;
  }
</style>

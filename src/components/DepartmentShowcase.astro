---
import { DEPARTMENTS, POSITIONS, SITE_CONFIG } from '../data/recruitmentData';
---

<section id="positions" class="department-showcase-section">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">ตำแหน่งที่เปิดรับสมัครของ 4 ฝ่ายงาน</span>
      <h2 class="section-title">โครงสร้าง 8 ตำแหน่งใน 4 ฝ่ายของบอร์ดวิชาการ</h2>
    </div>

    <!-- Department Quick Jump Tabs -->
    <div class="dept-tabs-container">
      <div class="dept-tabs" role="navigation" aria-label="ข้ามไปยังฝ่ายงาน">
        {DEPARTMENTS.map((dept) => (
          <a href={`#dept-${dept.id}`} class="dept-tab">
            <span class="tab-icon">
              {dept.id === 'it' && '💻'}
              {dept.id === 'record' && '🎥'}
              {dept.id === 'core' && '📚'}
              {dept.id === 'pr' && '📢'}
            </span>
            <span class="tab-text">
              {dept.nameThai}
              <span class="tab-count">({dept.totalOpenings} อัตรา)</span>
            </span>
          </a>
        ))}
      </div>
    </div>

    <!-- Department Sections List -->
    <div class="departments-list">
      {DEPARTMENTS.map((dept, deptIdx) => {
        const deptPositions = POSITIONS.filter(pos => pos.departmentId === dept.id);
        return (
          <div id={`dept-${dept.id}`} class="dept-block">
            <!-- Department Banner -->
            <div class="dept-banner">
              <div class="dept-banner-left">
                <span class="dept-number">0{deptIdx + 1}</span>
                <div class="dept-titles">
                  <h3 class="dept-title-eng">{dept.nameEnglish}</h3>
                  <p class="dept-title-thai">{dept.nameThai} • เปิดรับรวม <strong class="highlight-num">{dept.totalOpenings} อัตรา</strong> ({dept.totalPositions} ทีมงาน)</p>
                </div>
              </div>
              <div class="dept-banner-right">
                <p class="dept-description">{dept.description}</p>
              </div>
            </div>

            <!-- Positions Grid in Department -->
            <div class="positions-stack">
              {deptPositions.map((pos) => (
                <div id={`detail-${pos.id}`} class="position-card">
                  <!-- Position Header -->
                  <div class="pos-card-header">
                    <div class="header-left">
                      <span class="team-group-badge">{pos.teamGroup}</span>
                      <h4 class="pos-thai">{pos.titleThai}</h4>
                      <p class="pos-eng">{pos.titleEnglish}</p>
                    </div>
                    <div class="header-right">
                      <span class="openings-badge">{pos.openingsText}</span>
                    </div>
                  </div>

                  <p class="pos-summary-box">{pos.summary}</p>

                  <div class="pos-tags">
                    {pos.skillTags.map((tag) => (
                      <span class="pos-tag">{tag}</span>
                    ))}
                  </div>

                  <!-- Full Details Sections (Easy to Read Columns) -->
                  <div class="pos-details-container">
                    <div class="detail-section">
                      <h5 class="detail-title">
                        <span class="title-icon">📋</span> หน้าที่ความรับผิดชอบหลัก (Core Responsibilities)
                      </h5>
                      <ul class="detail-list check-list">
                        {pos.responsibilities.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    </div>

                    <div class="detail-section">
                      <h5 class="detail-title">
                        <span class="title-icon">🌟</span> คุณสมบัติของผู้สมัคร (Qualifications)
                      </h5>
                      <ul class="detail-list star-list">
                        {pos.qualifications.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    </div>

                    <div class="detail-row-2col">
                      <div class="detail-section mini-section">
                        <h5 class="detail-title">
                          <span class="title-icon">🛠️</span> เครื่องมือและทักษะที่เกี่ยวข้อง
                        </h5>
                        <ul class="detail-list bullet-list">
                          {pos.toolsAndSkills.map((item) => (
                            <li>{item}</li>
                          ))}
                        </ul>
                      </div>

                      <div class="detail-section mini-section">
                        <h5 class="detail-title">
                          <span class="title-icon">💡</span> สิ่งที่ทีมให้ความสำคัญ (Team Values)
                        </h5>
                        <ul class="detail-list bullet-list">
                          {pos.teamValues.map((item) => (
                            <li>{item}</li>
                          ))}
                        </ul>
                      </div>
                    </div>

                    {pos.note && (
                      <div class="pos-note-box">
                        <span class="note-icon">📌</span>
                        <p>{pos.note}</p>
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .department-showcase-section {
    padding: 5rem 0 5.5rem;
    background-color: var(--bg-subtle);
    border-top: 1px solid var(--border-subtle);
  }

  .section-header {
    max-width: 46rem;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .section-badge {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--accent);
    background: #e0e7ff;
    padding: 0.35rem 0.95rem;
    border-radius: var(--radius-full);
    margin-bottom: 0.875rem;
  }

  .section-title {
    font-size: 1.875rem;
    color: var(--primary);
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: 2.35rem;
    }
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* Filter Tabs */
  .dept-tabs-container {
    margin-bottom: 3.5rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
  }

  .dept-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    width: 100%;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .dept-tabs {
      justify-content: flex-start;
      padding: 0 0.5rem;
    }
  }

  .dept-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.15rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-subtle);
    background: #ffffff;
    color: var(--text-main);
    font-size: 0.9375rem;
    font-weight: 700;
    cursor: pointer;
    transition: all var(--transition-fast);
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
  }

  .dept-tab:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  .dept-tab.active {
    background: var(--primary);
    color: #ffffff;
    border-color: var(--primary);
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15);
  }

  .tab-count {
    font-weight: 600;
    opacity: 0.85;
    font-size: 0.85rem;
  }

  .dept-tab.tab-record {
    border-color: #fcd34d;
  }

  .dept-tab.tab-record.active {
    background: #d97706;
    border-color: #d97706;
  }

  /* Departments List */
  .departments-list {
    display: flex;
    flex-direction: column;
    gap: 4.5rem;
  }

  .dept-block {
    background: transparent;
  }

  .dept-banner {
    background: #ffffff;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: 2rem 2.25rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    box-shadow: var(--shadow-sm);
  }

  @media (min-width: 992px) {
    .dept-banner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .dept-banner-left {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .dept-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-full);
    background: var(--primary);
    color: #ffffff;
    font-size: 1.125rem;
    font-weight: 800;
    flex-shrink: 0;
  }

  .dept-titles {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .dept-title-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .dept-title-eng {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--primary);
    margin: 0;
  }

  .ind-badge {
    background: #fef3c7;
    color: #b45309;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.65rem;
    border-radius: var(--radius-full);
    border: 1px solid #fde68a;
  }

  .dept-title-thai {
    font-size: 1rem;
    color: var(--text-muted);
    margin: 0;
  }

  .highlight-num {
    color: var(--accent);
  }

  .dept-banner-right {
    max-width: 34rem;
  }

  .dept-description {
    font-size: 0.98rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
  }

  .record-alert-box {
    background: #fffbeb;
    border: 1.5px solid #fde68a;
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    color: #92400e;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .alert-icon {
    font-size: 1.35rem;
    flex-shrink: 0;
  }

  /* Positions Stack inside Department */
  .positions-stack {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .position-card {
    background: #ffffff;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: 2.25rem;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-fast), border-color var(--transition-fast);
  }

  .position-card:hover {
    box-shadow: var(--shadow-md);
    border-color: #cbd5e1;
  }

  @media (max-width: 640px) {
    .position-card {
      padding: 1.5rem;
    }
  }

  .pos-card-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  @media (min-width: 640px) {
    .pos-card-header {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
    }
  }

  .header-left {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .team-group-badge {
    font-size: 0.78rem;
    font-weight: 800;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .pos-thai {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--primary);
    margin: 0;
  }

  .pos-eng {
    font-size: 0.95rem;
    color: var(--text-light);
    font-weight: 600;
    margin: 0;
  }

  .openings-badge {
    display: inline-block;
    background: #e0e7ff;
    color: var(--primary);
    font-size: 0.95rem;
    font-weight: 800;
    padding: 0.45rem 1rem;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .pos-summary-box {
    font-size: 1.05rem;
    color: var(--text-main);
    font-weight: 600;
    line-height: 1.6;
    margin-bottom: 1.25rem;
    background: #f8fafc;
    padding: 1rem 1.25rem;
    border-left: 4px solid var(--accent);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .pos-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .pos-tag {
    font-size: 0.8rem;
    font-weight: 600;
    color: #334155;
    background: #f1f5f9;
    border: 1px solid var(--border-subtle);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-full);
  }

  /* Full Details Columns */
  .pos-details-container {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .detail-section {
    background: #ffffff;
  }

  .detail-title {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .title-icon {
    font-size: 1.15rem;
  }

  .detail-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .detail-list li {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    position: relative;
    padding-left: 1.6rem;
  }

  .check-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: #10b981;
    font-weight: 800;
  }

  .star-list li::before {
    content: "★";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-size: 0.85rem;
  }

  .bullet-list li::before {
    content: "•";
    position: absolute;
    left: 0.25rem;
    top: 0;
    color: #94a3b8;
    font-weight: 800;
  }

  .detail-row-2col {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
    padding-top: 0.5rem;
  }

  @media (min-width: 768px) {
    .detail-row-2col {
      grid-template-columns: 1fr 1fr;
    }
  }

  .mini-section {
    background: #f8fafc;
    padding: 1.25rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
  }

  .pos-note-box {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    color: #1e40af;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .pos-note-box p {
    margin: 0;
  }

  .pos-card-footer {
    margin-top: 2.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-subtle);
    display: flex;
    justify-content: flex-end;
  }

  .btn-apply-pos {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--primary);
    color: #ffffff;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    transition: background-color var(--transition-fast), transform var(--transition-fast);
  }

  .btn-apply-pos:hover {
    background: var(--accent);
    transform: translateY(-2px);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.dept-tab');
    const deptBlocks = document.querySelectorAll('.dept-block');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const filter = tab.getAttribute('data-filter');

        // Update active tab state
        tabs.forEach((t) => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');

        // Filter departments
        deptBlocks.forEach((block) => {
          const deptId = block.getAttribute('data-dept');
          if (filter === 'all' || deptId === filter) {
            (block as HTMLElement).style.display = 'block';
          } else {
            (block as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  });
</script>

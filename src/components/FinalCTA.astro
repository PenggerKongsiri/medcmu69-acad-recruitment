---
import { SITE_CONFIG } from '../data/recruitmentData';
---

<section class="cta-section">
  <div class="container">
    <div class="cta-box animate-fade-up">
      <div class="cta-content">
        <span class="cta-badge">MEDCMU69 ACADEMIC RECRUITMENT</span>
        <h2 class="cta-title">พร้อมเป็นส่วนหนึ่งของทีมฝ่ายวิชาการ MEDCMU69 แล้วหรือยัง?</h2>
        <p class="cta-desc">
          มาร่วมกันสร้างสรรค์สื่อการเรียนรู้ ระบบสนับสนุนการเรียน และขับเคลื่อนวิชาการของเพื่อนนักศึกษาแพทย์ มช. รุ่นที่ 69 ไปด้วยกัน
        </p>

        <div class="cta-actions">
          <a href="#apply" class="btn-cta">
            <span>เริ่มกรอกใบสมัคร</span>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 2rem 0 5rem;
    background-color: var(--bg-page);
  }

  .cta-box {
    background: linear-gradient(135deg, #1E1B4B 0%, #312E81 50%, #3B0764 100%);
    border-radius: var(--radius-lg);
    padding: 3.5rem 1.5rem;
    text-align: center;
    color: #ffffff;
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  @media (min-width: 768px) {
    .cta-box {
      padding: 4.5rem 3rem;
    }
  }

  .cta-content {
    max-width: 44rem;
    margin: 0 auto;
  }

  .cta-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: #C7D2FE;
    background: rgba(255, 255, 255, 0.12);
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    margin-bottom: 1.25rem;
  }

  .cta-title {
    font-size: 1.875rem;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 1.15rem;
    line-height: 1.35;
  }

  @media (min-width: 768px) {
    .cta-title {
      font-size: 2.35rem;
    }
  }

  .cta-desc {
    font-size: 1.0625rem;
    color: #E0E7FF;
    margin-bottom: 2.25rem;
    line-height: 1.7;
  }

  .cta-actions {
    display: flex;
    justify-content: center;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    background-color: #ffffff;
    color: #1E1B4B;
    font-weight: 800;
    font-size: 1.05rem;
    padding: 0.95rem 2.25rem;
    border-radius: var(--radius-full);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), background-color var(--transition-fast);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
    text-decoration: none;
  }

  .btn-cta:hover {
    background-color: #F8FAFC;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.35);
  }
</style>

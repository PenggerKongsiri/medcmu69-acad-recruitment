---
import { CORE_EXPECTATIONS } from '../data/recruitmentData';
---

<section class="expectations-section">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">คุณสมบัติร่วมของสมาชิก</span>
      <h2 class="section-title">สิ่งที่เราให้ความสำคัญในทุกตำแหน่ง</h2>
      <p class="section-subtitle">
        ไม่ว่าคุณจะอยู่ทีมใด คุณลักษณะและทัศนคติเหล่านี้คือหัวใจสำคัญในการทำงานร่วมกันในฝ่ายวิชาการ MEDCMU69
      </p>
    </div>

    <div class="expectations-grid">
      {CORE_EXPECTATIONS.map((exp, index) => (
        <div class="exp-card animate-fade-up" style={`animation-delay: ${index * 80}ms;`}>
          <div class="exp-number">0{index + 1}</div>
          <h3 class="exp-title">{exp.title}</h3>
          <p class="exp-desc">{exp.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .expectations-section {
    padding: 4.5rem 0 5rem;
    background-color: var(--bg-subtle);
    border-top: 1px solid var(--border-subtle);
  }

  .section-header {
    max-width: 44rem;
    margin: 0 auto 3.5rem;
    text-align: center;
  }

  .section-badge {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--accent);
    background: #e0e7ff;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    margin-bottom: 0.875rem;
  }

  .section-title {
    font-size: 1.875rem;
    color: var(--primary);
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: 2.25rem;
    }
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--text-muted);
  }

  .expectations-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .expectations-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .expectations-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .exp-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: 1.75rem 1.5rem;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), border-color var(--transition-fast);
    display: flex;
    flex-direction: column;
  }

  .exp-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
  }

  .exp-number {
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--accent);
    background: #f1f5f9;
    padding: 0.25rem 0.65rem;
    border-radius: var(--radius-full);
    width: fit-content;
    margin-bottom: 1rem;
  }

  .exp-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 0.65rem;
  }

  .exp-desc {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.65;
  }
</style>

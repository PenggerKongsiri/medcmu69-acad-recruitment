---
import { APPLICATION_TIMELINE } from '../data/recruitmentData';
---

<section id="timeline" class="timeline-section">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">ขั้นตอนการรับสมัคร</span>
      <h2 class="section-title">5 ขั้นตอนสู่การเป็นส่วนหนึ่งของทีม</h2>
      <p class="section-subtitle">
        กระบวนการรับสมัครเรียบง่าย ชัดเจน และให้คุณได้เลือกสายงานที่สนใจตามความถนัดของตนเอง
      </p>
    </div>

    <div class="timeline-wrapper">
      <div class="timeline-line"></div>
      {APPLICATION_TIMELINE.map((step, idx) => (
        <div class="timeline-step animate-fade-up" style={`animation-delay: ${idx * 100}ms;`}>
          <div class="step-badge">
            <span>{step.stepNumber}</span>
          </div>
          <div class="step-card">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline-section {
    padding: 5rem 0;
    background-color: var(--bg-page);
  }

  .section-header {
    max-width: 44rem;
    margin: 0 auto 3.5rem;
    text-align: center;
  }

  .section-badge {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--accent);
    background: #e0e7ff;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    margin-bottom: 0.875rem;
  }

  .section-title {
    font-size: 1.875rem;
    color: var(--primary);
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: 2.25rem;
    }
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--text-muted);
  }

  .timeline-wrapper {
    position: relative;
    max-width: 48rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .timeline-line {
    position: absolute;
    top: 1.5rem;
    bottom: 1.5rem;
    left: 1.25rem;
    width: 2px;
    background: var(--border-subtle);
  }

  @media (min-width: 640px) {
    .timeline-line {
      left: 1.75rem;
    }
  }

  .timeline-step {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .step-badge {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-full);
    background: var(--accent);
    color: #ffffff;
    font-weight: 800;
    font-size: 1.1rem;
    flex-shrink: 0;
    box-shadow: 0 0 0 6px var(--bg-page);
  }

  @media (min-width: 640px) {
    .step-badge {
      width: 3.5rem;
      height: 3.5rem;
      font-size: 1.25rem;
    }
  }

  .step-card {
    flex-grow: 1;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast), border-color var(--transition-fast);
  }

  .step-card:hover {
    transform: translateX(4px);
    border-color: var(--accent);
  }

  .step-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 0.5rem;
  }

  .step-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.65;
  }
</style>

---
import { DEPARTMENTS, POSITIONS, SITE_CONFIG } from '../data/recruitmentData';
---

<section class="positions-details-section">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">รายละเอียดฉบับเต็ม</span>
      <h2 class="section-title">เจาะลึก 8 ตำแหน่ง แยกตาม 4 ฝ่ายงาน</h2>
      <p class="section-subtitle">
        ศึกษาหน้าที่หลัก คุณสมบัติ และสิ่งที่ฝ่ายให้ความสำคัญ เพื่อเตรียมพร้อมก่อนกรอกใบสมัครจริง
      </p>
    </div>

    <div class="departments-accordion-wrapper">
      {DEPARTMENTS.map((dept, deptIdx) => {
        const deptPositions = POSITIONS.filter(pos => pos.departmentId === dept.id);
        return (
          <div class="dept-detail-group">
            <div class="dept-detail-banner">
              <div class="banner-left">
                <span class="banner-num">0{deptIdx + 1}</span>
                <div>
                  <h3 class="banner-title">{dept.nameEnglish} ({dept.nameThai})</h3>
                  <p class="banner-sub">{dept.description}</p>
                </div>
              </div>
              <span class="banner-stats">เปิดรับ {dept.totalOpenings} อัตรา</span>
            </div>

            <div class="accordion-list">
              {deptPositions.map((pos, idx) => (
                <div id={`detail-${pos.id}`} class="accordion-item">
                  <h4>
                    <button
                      class="accordion-trigger"
                      aria-expanded={deptIdx === 0 && idx === 0 ? "true" : "false"}
                      aria-controls={`panel-${pos.id}`}
                      id={`trigger-${pos.id}`}
                    >
                      <div class="trigger-left">
                        <span class="team-badge">{pos.teamGroup}</span>
                        <div class="trigger-titles">
                          <span class="trigger-thai">{pos.titleThai}</span>
                          <span class="trigger-eng">{pos.titleEnglish} • <strong class="text-indigo">{pos.openingsText}</strong></span>
                        </div>
                      </div>
                      <div class="trigger-icon" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path class="chevron-path" d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </div>
                    </button>
                  </h4>

                  <div
                    id={`panel-${pos.id}`}
                    class="accordion-panel"
                    role="region"
                    aria-labelledby={`trigger-${pos.id}`}
                    hidden={!(deptIdx === 0 && idx === 0)}
                  >
                    <div class="panel-content">
                      <div class="panel-summary">
                        <p class="summary-text">{pos.summary}</p>
                      </div>

                      <div class="details-grid">
                        <!-- Core Responsibilities -->
                        <div class="detail-block">
                          <h5 class="block-title">
                            <span class="block-icon">📌</span> หน้าที่หลัก (Core Responsibilities)
                          </h5>
                          <ul class="detail-list">
                            {pos.responsibilities.map((item) => (
                              <li>{item}</li>
                            ))}
                          </ul>
                        </div>

                        <!-- Qualifications -->
                        <div class="detail-block">
                          <h5 class="block-title">
                            <span class="block-icon">🌟</span> คุณสมบัติที่เหมาะสม (Qualifications)
                          </h5>
                          <ul class="detail-list">
                            {pos.qualifications.map((item) => (
                              <li>{item}</li>
                            ))}
                          </ul>
                        </div>

                        <!-- Tools and Skills -->
                        <div class="detail-block">
                          <h5 class="block-title">
                            <span class="block-icon">🛠️</span> เครื่องมือหรือทักษะที่เกี่ยวข้อง
                          </h5>
                          <ul class="detail-list">
                            {pos.toolsAndSkills.map((item) => (
                              <li>{item}</li>
                            ))}
                          </ul>
                        </div>

                        <!-- Team Values -->
                        <div class="detail-block">
                          <h5 class="block-title">
                            <span class="block-icon">💡</span> สิ่งที่ทีมให้ความสำคัญ
                          </h5>
                          <ul class="detail-list">
                            {pos.teamValues.map((item) => (
                              <li>{item}</li>
                            ))}
                          </ul>
                        </div>
                      </div>

                      {pos.note && (
                        <div class="panel-note">
                          <div class="note-icon">💡</div>
                          <p class="note-text">{pos.note}</p>
                        </div>
                      )}

                      <div class="panel-cta">
                        <a href="#apply" class="btn-primary apply-now-btn">
                          <span>สมัครตำแหน่ง {pos.titleThai}</span>
                          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  const triggers = document.querySelectorAll('.accordion-trigger');

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
      const panelId = trigger.getAttribute('aria-controls');
      if (!panelId) return;

      const panel = document.getElementById(panelId);
      if (!panel) return;

      trigger.setAttribute('aria-expanded', String(!isExpanded));
      panel.hidden = isExpanded;
    });
  });
</script>

<style>
  .positions-details-section {
    padding: 3rem 0 5rem;
    background-color: var(--bg-subtle);
  }

  .section-header {
    max-width: 44rem;
    margin: 0 auto 3.5rem;
    text-align: center;
  }

  .section-badge {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--accent);
    background: #e0e7ff;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    margin-bottom: 0.875rem;
  }

  .section-title {
    font-size: 1.875rem;
    color: var(--primary);
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: 2.25rem;
    }
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--text-muted);
  }

  .departments-accordion-wrapper {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    max-width: 58rem;
    margin: 0 auto;
  }

  .dept-detail-group {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .dept-detail-banner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
    justify-content: space-between;
    background: var(--primary);
    color: #ffffff;
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius-md);
  }

  @media (min-width: 640px) {
    .dept-detail-banner {
      flex-direction: row;
      align-items: center;
    }
  }

  .banner-left {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .banner-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.15);
    color: #ffffff;
    font-weight: 800;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .banner-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: #ffffff;
    margin: 0;
  }

  .banner-sub {
    font-size: 0.85rem;
    color: #E0E7FF;
    margin: 0.2rem 0 0;
  }

  .banner-stats {
    font-size: 0.85rem;
    font-weight: 700;
    color: #ffffff;
    background: var(--accent);
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .accordion-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .accordion-item {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: border-color var(--transition-fast);
  }

  .accordion-item:target {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.15);
  }

  h4 {
    margin: 0;
  }

  .accordion-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background-color var(--transition-fast);
  }

  .accordion-trigger:hover {
    background-color: #f8fafc;
  }

  .trigger-left {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .trigger-left {
      align-items: center;
    }
  }

  .team-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent);
    background: #e0e7ff;
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  @media (min-width: 640px) {
    .team-badge {
      margin-top: 0;
    }
  }

  .trigger-titles {
    display: flex;
    flex-direction: column;
    word-break: break-word;
  }

  .trigger-thai {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--primary);
  }

  .trigger-eng {
    font-size: 0.875rem;
    color: var(--text-light);
    line-height: 1.4;
    word-break: break-word;
  }

  .text-indigo {
    color: var(--accent);
    font-weight: 700;
  }

  .trigger-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-full);
    background: #f1f5f9;
    color: var(--primary);
    transition: transform var(--transition-fast), background-color var(--transition-fast);
    flex-shrink: 0;
  }

  .accordion-trigger[aria-expanded="true"] .trigger-icon {
    transform: rotate(180deg);
    background: var(--accent);
    color: #ffffff;
  }

  .accordion-panel {
    border-top: 1px solid var(--border-subtle);
  }

  .panel-content {
    padding: 1.75rem 1.5rem 2rem;
  }

  @media (min-width: 640px) {
    .panel-content {
      padding: 2rem 2.25rem 2.25rem;
    }
  }

  .panel-summary {
    background: #f8fafc;
    border-left: 4px solid var(--accent);
    padding: 1rem 1.25rem;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    margin-bottom: 2rem;
  }

  .summary-text {
    font-size: 1rem;
    font-weight: 600;
    color: var(--primary);
    line-height: 1.6;
  }

  .details-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .details-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .block-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.05rem;
    color: var(--primary);
    margin-bottom: 0.875rem;
  }

  .detail-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .detail-list li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .detail-list li::before {
    content: "";
    position: absolute;
    left: 0.25rem;
    top: 0.65rem;
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background-color: var(--accent);
  }

  .panel-note {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    background: var(--accent-violet-light);
    border: 1px solid #e9d5ff;
    border-radius: var(--radius-sm);
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
  }

  .note-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .note-text {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--accent-violet);
    line-height: 1.6;
  }

  .panel-cta {
    display: flex;
    justify-content: flex-end;
  }

  .apply-now-btn {
    width: 100%;
  }

  @media (min-width: 640px) {
    .apply-now-btn {
      width: auto;
    }
  }
</style>

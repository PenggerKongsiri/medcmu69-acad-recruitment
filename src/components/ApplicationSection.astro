---
import { SITE_CONFIG } from '../data/recruitmentData';

const applicationUrl = SITE_CONFIG.applicationUrl;
---

<section id="apply" class="application-section">
  <div class="container">
    <div class="section-header animate-fade-up">
      <span class="section-badge">ONLINE APPLICATION</span>
      <h2 class="section-title">กรอกใบสมัคร</h2>
      <p class="section-subtitle">
        กรุณาตรวจสอบข้อมูลและตำแหน่งที่สนใจก่อนเริ่มกรอก
        แบบฟอร์มจะแสดงคำถามเฉพาะทีมที่เลือกเป็นอันดับที่ 1
      </p>
    </div>

    <div class="form-embed-box animate-fade-up" style="animation-delay: 150ms;">
      <div class="iframe-wrapper">
        <iframe
          style="border:none;width:100%;"
          id="acad"
          src={applicationUrl}
          title="ใบสมัครสมาชิกฝ่ายวิชาการ MEDCMU69"
          loading="lazy"
          allow="clipboard-write"
        ></iframe>
        <script
          is:inline
          type="text/javascript"
          onload="initEmbed('acad'); if(document.readyState !== 'loading' && typeof iFrameResize === 'function'){ iFrameResize({log:!1,checkOrigin:!1},'#acad'); }"
          src="/widgets/iframe.min.js"
        ></script>
      </div>
    </div>

    <p class="form-fallback">
      หากแบบฟอร์มไม่แสดง
      <a href={applicationUrl} target="_blank" rel="noopener noreferrer">เปิดแบบฟอร์มในหน้าใหม่</a>
    </p>
  </div>
</section>

<style>
  .application-section {
    padding: 5rem 0 6rem;
    background: linear-gradient(180deg, var(--bg-page) 0%, var(--bg-subtle) 100%);
    border-top: 1px solid var(--border-subtle);
  }

  .section-header {
    max-width: 48rem;
    margin: 0 auto 2.75rem;
    text-align: center;
  }

  .section-badge {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--accent);
    background: var(--accent-indigo-light);
    padding: 0.35rem 0.95rem;
    border-radius: var(--radius-full);
    margin-bottom: 0.875rem;
    letter-spacing: 0.05em;
  }

  .section-title {
    font-size: 2rem;
    color: var(--primary);
    margin-bottom: 1rem;
    word-break: break-word;
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: 2.45rem;
    }
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.75;
    word-break: break-word;
  }

  .form-embed-box {
    max-width: 68rem;
    margin: 0 auto;
    background: #ffffff;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    width: 100%;
  }

  .iframe-wrapper {
    position: relative;
    width: 100%;
    min-height: 700px;
    -webkit-overflow-scrolling: touch;
  }

  .iframe-wrapper iframe {
    width: 100%;
    min-height: 700px;
    border: 0;
    display: block;
  }

  @media (max-width: 640px) {
    .application-section {
      padding: 3.5rem 0 4.5rem;
    }

    .form-embed-box {
      border-radius: var(--radius-md);
    }

    .iframe-wrapper {
      min-height: 540px;
    }

    .iframe-wrapper iframe {
      min-height: 540px;
    }
  }

  .form-fallback {
    margin: 1.5rem 0 0;
    text-align: center;
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .form-fallback a {
    color: var(--accent);
    font-weight: 700;
    text-decoration: underline;
    margin-left: 0.35rem;
    transition: color var(--transition-fast);
  }

  .form-fallback a:hover {
    color: var(--primary);
  }
</style>
